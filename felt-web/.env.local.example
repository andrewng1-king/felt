# felt. Read engine — copy this file to .env.local and fill in ONE provider key.
# .env.local is gitignored, so your key is never committed.
#
#   cp .env.local.example .env.local     (mac/linux)
#   copy .env.local.example .env.local   (windows)

# Which provider to use: gemini | groq | anthropic | dry-run
# Default is gemini. With no key set, the engine runs in dry-run (shaped
# placeholder Reads) so the console still works.
FELT_PROVIDER=gemini

# Optional — override the model id. Defaults per provider:
#   gemini    -> gemini-2.0-flash    (free tier; try gemini-2.5-pro for more voice)
#   groq      -> llama-3.3-70b-versatile
#   anthropic -> claude-sonnet-5     (best voice; use claude-opus-4-8 for the real 5 Reads)
# FELT_MODEL=

# --- Provider keys: set the one matching FELT_PROVIDER above ---

# Gemini — free key from https://aistudio.google.com/apikey  (recommended to start)
GEMINI_API_KEY=

# Groq — free key from https://console.groq.com/keys
# GROQ_API_KEY=

# Anthropic (Claude) — https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=
